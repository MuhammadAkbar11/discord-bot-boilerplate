{
  "name": "discord-bot-boilerplate",
  "version": "1.0.0",
  "description": "A clean, class-based Discord.js boilerplate built with TypeScript and Mongoose.",
  "main": "index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./build",
    "build": "tsc --build",
    "start": "yarn clean && yarn build && node build/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "mongoose": "^9.6.1",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
