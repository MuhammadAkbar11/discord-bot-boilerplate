{
  "name": "discord-bot-boilerplate",
  "version": "2.0.0",
  "description": "A clean, class-based Discord.js boilerplate built with TypeScript and Mongoose.",
  "main": "index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./build",
    "build": "tsc --build",
    "start": "yarn clean && yarn build && node build/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "mongoose": "^9.6.1",
    "ms": "^2.1.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
