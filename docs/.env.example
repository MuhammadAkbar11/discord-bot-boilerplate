# --- PRODUCTION CONFIG ---
# Main bot token and client ID
DISCORD_TOKEN=your_production_token_here
DISCORD_CLIENT_ID=your_production_client_id_here

# --- DEVELOPMENT CONFIG ---
# (Optional) Separate token and client ID for your dev bot
DEV_DISCORD_TOKEN=your_development_token_here
DEV_DISCORD_CLIENT_ID=your_development_client_id_here

# The ID of the guild where you test your dev bot
# Commands are registered instantly in this guild when in dev mode
DEV_GUILD_ID=your_test_guild_id_here

# --- DATABASE ---
MONGO_URL=your_mongodb_connection_string_here
